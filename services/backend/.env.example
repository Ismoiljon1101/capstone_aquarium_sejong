# Set to true only for local dev without Arduino hardware
SIMULATE_SENSORS=false

# Database Connection (Leave empty to default to SQLite 'fishlinic.sqlite' file)
# When running inside Docker Compose, point to the PostgreSQL service container:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/fishlinic
DATABASE_URL=

# Serial bridge URL (used by ActuatorsService to communicate with physical Arduino)
# NOTE: The serial-bridge MUST run natively on the host machine to access COM/USB ports.
SERIAL_BRIDGE_URL=http://localhost:3001

# AI Predictor Service URL (FastAPI RF Model)
AI_PREDICTOR_URL=http://localhost:8000

# Local AI LLM Configuration (Ollama Fallback)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=batiai/gemma4-e4b:q4

# Cloud LLM Configuration (OpenRouter)
# Get your API key at https://openrouter.ai/
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.0-flash-lite:free
