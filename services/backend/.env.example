# Set to true only for local dev without Arduino hardware
SIMULATE_SENSORS=false

# Database (SQLite default, no config needed)
# DB_PATH=./data/fishlinic.db

# Serial bridge URL (used by ActuatorsService)
SERIAL_BRIDGE_URL=http://localhost:3001

# AI & LLM Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=batiai/gemma4-e4b:q4

# Cloud LLM Configuration (OpenRouter)
# Get your key at https://openrouter.ai/
LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=google/gemini-flash-1.5
