{
  "name": "fishlinic",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter \"*\" run dev",
    "install:all": "pnpm install",
    "start": "pnpm --parallel --filter \"*\" run dev"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "shared"
  ],
  "dependencies": {
    "sqlite3": "^6.0.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sqlite3",
      "better-sqlite3",
      "bcryp",
      "@parcel/watcher"
    ],
    "overrides": {
      "@types/react": "18.2.79",
      "@types/react-dom": "18.2.25",
      "@types/react-native": "0.73.0"
    }
  }
}