{
  "name": "fishlinic",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter \"*\" run dev",
    "install:all": "pnpm install",
    "start": "pnpm --parallel --filter \"*\" run dev"
  },
  "workspaces": [
    "apps/*",
    "services/*",
    "shared"
  ],
  "dependencies": {},
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "bcrypt",
      "@parcel/watcher",
      "@nestjs/core",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "@types/react": "18.2.79",
      "@types/react-dom": "18.2.25",
      "@types/react-native": "0.73.0"
    }
  }
}