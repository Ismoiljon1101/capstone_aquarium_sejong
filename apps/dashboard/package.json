{
  "name": "fishlinic",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:ui": "next dev -p 3000",
    "dev:bridge": "tsx mock-server/index.ts",
    "dev": "next dev",
    "build": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next build --webpack",
    "build:prod": "cross-env NODE_ENV=production next build --webpack",
    "start": "next start",
    "start:prod:all": "run-p start:ui:prod start:bridge:prod",
    "start:ui:prod": "cross-env NODE_ENV=production next start -p 3000",
    "start:bridge:prod": "cd mock-server && npm run start:prod",
    "exhibition": "npm run build && npm run start:core",
    "lint": "eslint",
    "db:generate": "echo \"Direct DB model usage\"",
    "db:push": "echo \"Prisma removed\""
  },
  "dependencies": {
    "@fishlinic/types": "workspace:*",
    "@neondatabase/serverless": "^1.0.2",
    "@serialport/parser-readline": "^13.0.0",
    "@vercel/analytics": "^1.6.1",
    "axios": "^1.15.0",
    "dotenv": "^17.2.2",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "express": "^5.1.0",
    "lucide-react": "^0.548.0",
    "next": "16.0.10",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-icons": "^5.5.0",
    "react-qr-code": "^2.0.12",
    "serialport": "^13.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.7.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.3",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.5",
    "typescript": "^5"
  }
}
