{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (NestJS)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "backend", "run", "dev"],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "Serial Bridge (Mock Arduino)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "serial-bridge", "run", "dev"],
      "port": 3001
    },
    {
      "name": "Dashboard (Next.js)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "fishlinic", "run", "dev"],
      "port": 3002
    },
    {
      "name": "Expo Mobile",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "fishlinic-mobile", "exec", "expo", "start", "--web", "--clear"],
      "port": 8081,
      "autoPort": true
    },
    {
      "name": "AI Predictor (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8001", "--app-dir", "services/ai-predictor"],
      "env": {
        "MODEL_PATH": "resources/models"
      },
      "port": 8001
    }
  ]
}
