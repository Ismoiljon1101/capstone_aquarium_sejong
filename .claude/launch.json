{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (NestJS)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "backend", "run", "dev"],
      "port": 3000
    },
    {
      "name": "Serial Bridge (Mock Arduino)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "serial-bridge", "run", "dev"],
      "port": 3001
    },
    {
      "name": "Dashboard (Next.js)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "fishlinic", "run", "dev"],
      "port": 3002
    },
    {
      "name": "Expo Mobile",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter", "fishlinic-mobile", "exec", "expo", "start", "--web", "--port", "8081"],
      "port": 8081
    },
    {
      "name": "AI Predictor (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "port": 8000
    }
  ]
}
