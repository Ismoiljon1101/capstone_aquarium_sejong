%% ══════════════════════════════════════════

    BE -->|"⑧ WRITE via TypeORM
    sensor_reading · alert
    voice_session · health_report
    fish_count · fish_growth
    camera_snapshot · user_command"| DB

%% ══════════════════════════════════════════
%%  ⑨ DATABASE → NESTJS (TypeORM reads)
%%  Source: sensors.service · fish.service etc.
%% ══════════════════════════════════════════

    DB -->|"⑨ READ via TypeORM
    GET /sensors/latest
    GET /sensors/:id/readings
    GET /fish/health · GET /fish/count
    GET /alerts/active"| BE

%% ══════════════════════════════════════════
%%  ⑩⑪ NESTJS ↔ FASTAPI — Disease Detection
%%  Source: vision.service.ts — detectDisease()
