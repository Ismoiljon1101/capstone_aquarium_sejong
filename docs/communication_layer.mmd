%% ══════════════════════════════════════════
%%  ① HARDWARE → SERIAL BRIDGE
%%  Source: services/serial-bridge/src/index.ts
%% ══════════════════════════════════════════

    HW -->|"① USB Serial JSON
    {pH, temp_c, do_mg_l}
    continuous stream · 9600 baud"| SB

%% ══════════════════════════════════════════
%%  ② SERIAL BRIDGE → ARDUINO (relay back)
%%  Source: emitter.ts — forwardActuatorState()
%% ══════════════════════════════════════════

    SB -->|"② Serial write
    relay channel + state
    on actuator trigger"| HW

%% ══════════════════════════════════════════
%%  ③ SERIAL BRIDGE → NESTJS
%%  Source: emitter.ts — forwardReading()
%%  POST ${BACKEND_URL}/serial/reading
%% ══════════════════════════════════════════

    SB -->|"③ POST /serial/reading
    Partial SensorReading JSON
    emitter.forwardReading()"| BE

%% ══════════════════════════════════════════
%%  ④ SERIAL BRIDGE → NESTJS (actuator confirm)
%%  Source: emitter.ts — forwardActuatorState()
%%  POST ${BACKEND_URL}/actuators/state
%% ══════════════════════════════════════════

    SB -->|"④ POST /actuators/state
    { actuatorId, state, timestamp }
    emitter.forwardActuatorState()"| BE

%% ══════════════════════════════════════════
%%  ⑤ NESTJS → SERIAL BRIDGE (relay command)
%%  Source: serial.controller.ts @Post('command')
%% ══════════════════════════════════════════

    BE -->|"⑤ POST /serial/command
    serial.controller.ts
    relay command to Arduino"| SB

%% ══════════════════════════════════════════
%%  ⑥⑦ NESTJS ↔ SERIAL BRIDGE (camera)
%%  Source: vision.service.ts — requestSnapshot()
%%  POST ${BRIDGE_URL}/camera/snapshot
%% ══════════════════════════════════════════

    BE -->|"⑥ POST /camera/snapshot
    vision.service.ts
    request frame from ESP32-CAM"| SB

    SB -->|"⑦ HTTP response
    { imagePath: string }
    image saved on local disk"| BE

%% ══════════════════════════════════════════
%%  ⑧ NESTJS → DATABASE (TypeORM writes)
