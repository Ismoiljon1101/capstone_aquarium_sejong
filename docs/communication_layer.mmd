%% ══════════════════════════════════════════

    BE -->|"⑯ POST /api/chat
    { model, messages: [system+user] }
    sensor context bundled in prompt"| OL

    OL -->|"⑰ LLM response
    { message: { content: string } }
    data.message.content extracted"| BE

%% ══════════════════════════════════════════
%%  ⑱⑲ VOICE ASSISTANT ↔ OLLAMA (DIRECT)
%%  Source: apps/assistant/src/llm_manager.py
%%  from ollama import chat, ChatResponse
%%  ⚠️ BYPASSES NestJS — no sensor context!
%% ══════════════════════════════════════════

    VA -->|"⑱ ollama.chat()
    Python ollama library — DIRECT
    ⚠️ no sensor context bundled"| OL

    OL -->|"⑲ ChatResponse
    natural language answer
    passed to Kokoro-82M TTS"| VA

