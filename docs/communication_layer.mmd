%% ══════════════════════════════════════════

    BE -->|"⑩ POST /predict/disease
    { imagePath: string }
    YOLOv8 disease detection"| FP

    FP -->|"⑪ disease result
    { disease, confidence, bbox }
    YOLOv8 output"| BE

%% ══════════════════════════════════════════
%%  ⑫⑬ NESTJS ↔ FASTAPI — Fish Count
%%  Source: vision.service.ts — countFish()
%%  POST ${AI_URL}/predict/count
%% ══════════════════════════════════════════

    BE -->|"⑫ POST /predict/count
    { imagePath: string }
    YOLO fish count"| FP

    FP -->|"⑬ count result
    { count: int, confidence: float }
    YOLO detection count"| BE

%% ══════════════════════════════════════════
%%  ⑭⑮ NESTJS ↔ FASTAPI — Water Quality
%%  Source: vision.service.ts — getWaterQualityScore()
%%  POST ${AI_URL}/predict/quality
%% ══════════════════════════════════════════

    BE -->|"⑭ POST /predict/quality
    { pH, temp_c, do_mg_l }
    3-feature Random Forest input"| FP

    FP -->|"⑮ quality result
    { score: float, status: ok|warn|critical }
    Random Forest output"| BE

%% ══════════════════════════════════════════
%%  ⑯⑰ NESTJS ↔ OLLAMA — LLM (via NestJS)
%%  Source: voice.service.ts — handleQuery()
%%  POST ${OLLAMA_URL}/api/chat
